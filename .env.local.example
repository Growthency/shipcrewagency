# ============================================================================
#  SHIP CREW AGENCY  —  ENVIRONMENT TEMPLATE
#  Copy this file to ".env.local" and fill in the values.
#  Every key has step-by-step instructions in ".env.local" comments.
# ============================================================================

# 1) Supabase (Project Settings → API). Run supabase/schema.sql + create a
#    public "images" bucket. The site works without these (demo content).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# 2) Admin portal /taslima. Default: admin@shipcrewagency.com / ShipCrew@2026
#    Change with: npm run hash-password "YourNewPassword"
ADMIN_EMAIL=admin@shipcrewagency.com
ADMIN_PASSWORD_HASH=

# 3) Secrets — generate each with:
#    node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
SESSION_SECRET=
VAULT_SECRET=

# 4) WhatsApp floating button — full international number, digits only.
NEXT_PUBLIC_WHATSAPP_NUMBER=

# 5) Public site URL.
NEXT_PUBLIC_SITE_URL=https://shipcrewagency.com
